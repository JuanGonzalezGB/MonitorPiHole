# rpi-projects/.env
# Copia este archivo como .env y ajusta los valores a tu red.
# NUNCA subas el .env real a Git.

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://192.168.X.X:27017
MONGO_TIMEOUT_MS=3000

# ── Nombres de bases de datos ──────────────────────────────────────────────────
DB_SCANNER=scanner
DB_PIHOLE=pihole_db

# ── Colecciones (ajustar si tu app usa nombres distintos) ──────────────────────
COLLECTION_DEVICES=dispositivos

# ── Pi-hole ────────────────────────────────────────────────────────────────────
PIHOLE_HOST=192.168.X.X
PIHOLE_PORT=80
PIHOLE_PASSWORD=tu_password_de_pihole

# ── Network monitor ────────────────────────────────────────────────────────────
NETWORK_SUBNET=192.168.0.0/24
SCAN_INTERVAL_S=120
SCREEN_W=480
SCREEN_H=320
REFRESH_MS=30000
