[Unit]
Description=Network monitor collector (arp-scan)
After=network-online.target mongod.service
Wants=network-online.target

[Service]
Type=simple
User=username
WorkingDirectory=/home/username/MonitorPihole/network-monitor
ExecStart=/usr/bin/python3 /home/username/MonitorPiHole/network-monitor/collector.py
Restart=always
RestartSec=15

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
